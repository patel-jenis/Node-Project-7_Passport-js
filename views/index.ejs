<%- include('partials/authHeader') %>

    <body>
        <%- include('partials/aside') %>

            <!-- <a href="/auth/logOut">logOut</a> -->
            <main class="main-wrapper">
                <!-- ========== header start ========== -->
                <header class="header">
                    <div class="container-fluid">
                        <div class="row">
                            <div class="col-lg-5 col-md-5 col-6">
                                <div class="header-left d-flex align-items-center">
                                    <div class="menu-toggle-btn mr-15">
                                        <button id="menu-toggle" class="main-btn primary-btn btn-hover">
                                            <i class="lni lni-chevron-left me-2"></i> Menu
                                        </button>
                                    </div>
                                    <div class="header-search d-none d-md-flex">
                                        <form action="#">
                                            <input type="text" placeholder="Search..." />
                                            <button><i class="lni lni-search-alt"></i></button>
                                        </form>
                                    </div>
                                </div>
                            </div>
                            <div class="col-lg-7 col-md-7 col-6">
                                <div class="header-right d-flex justify-content-end align-items-center">

                                    <!-- Profile -->
                                    <!-- Profile (Hide on Mobile) -->
                                    <div class="profile-box me-4 d-none d-md-block">
                                        <div class="profile-info">
                                            <div class="info d-flex align-items-center">
                                                <div class="image me-2">
                                                    <img src="../assets/images/profile/profile-image.png" alt="profile">
                                                </div>
                                                <div>
                                                    <h6 class="fw-600 mb-0">Adam Joe</h6>
                                                    <small class="text-muted">Admin</small>
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                    <!-- Logout Button -->
                                    <a href="/auth/logOut"
                                        class="btn btn-outline-danger rounded-pill px-4 py-2 d-flex align-items-center gap-2">
                                        <i class="lni lni-exit"></i>
                                        <span>Logout</span>
                                    </a>

                                </div>
                            </div>
                        </div>
                    </div>
                </header>
                <!-- ========== header end ========== -->

                <!-- Dashboard Section -->
                <section class="section mt-5">
                    <div class="container-fluid">

                        <!-- Welcome Card -->
                        <div class="card shadow-sm border-0 mb-4">
                            <div class="card-body">
                                <div class="row align-items-center">
                                    <div class="col-lg-8">
                                        <h2 class="fw-bold mb-2">Welcome Back 👋</h2>
                                        <p class="text-muted mb-0">
                                            Manage blogs, content, and website settings from your admin dashboard.
                                        </p>
                                    </div>

                                    <div class="col-lg-4 text-lg-end mt-3 mt-lg-0">
                                        <a href="/blogs/add" class="btn btn-primary px-4">
                                            <i class="lni lni-plus me-2"></i>
                                            Create Blog
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Statistics -->
                        <div class="row">

                            <div class="col-md-6 mb-4">
                                <div class="card shadow-sm border-0 h-100">
                                    <div class="card-body d-flex align-items-center">

                                        <div class="bg-success text-white rounded p-3 me-3">
                                            <i class="lni lni-eye fs-3"></i>
                                        </div>

                                        <div>
                                            <h3 class="mb-1 fw-bold">1.2K</h3>
                                            <p class="text-muted mb-0">Total Views</p>
                                        </div>

                                    </div>
                                </div>
                            </div>

                            <div class="col-md-6 mb-4">
                                <div class="card shadow-sm border-0 h-100">
                                    <div class="card-body d-flex align-items-center">

                                        <div class="bg-warning text-white rounded p-3 me-3">
                                            <i class="lni lni-pencil fs-3"></i>
                                        </div>

                                        <div>
                                            <h3 class="mb-1 fw-bold">18</h3>
                                            <p class="text-muted mb-0">Published Posts</p>
                                        </div>

                                    </div>
                                </div>
                            </div>

                        </div>

                        <!-- Bottom Section -->
                        <div class="row">

                            <!-- Quick Actions -->
                            <div class="col-lg-6 mb-4">
                                <div class="card shadow-sm border-0 h-100">
                                    <div class="card-body p-4">

                                        <h5 class="fw-bold mb-4">Quick Actions</h5>

                                        <div class="d-grid gap-3">

                                            <a href="/blogs/add" class="btn btn-primary">
                                                <i class="lni lni-plus me-2"></i>
                                                Add New Blog
                                            </a>

                                            <a href="/blogs/view-Blogs" class="btn btn-outline-primary">
                                                <i class="lni lni-list me-2"></i>
                                                View All Blogs
                                            </a>

                                        </div>

                                    </div>
                                </div>
                            </div>

                            <!-- Admin Information -->
                            <div class="col-lg-6 mb-4">
                                <div class="card shadow-sm border-0 h-100">
                                    <div class="card-body p-4">

                                        <h5 class="fw-bold mb-4">Administrator</h5>

                                        <div class="d-flex align-items-center">

                                            <img src="/assets/images/profile/profile-image.png"
                                                class="rounded-circle me-3" width="80" height="80" alt="Admin">

                                            <div>
                                                <h5 class="mb-1">Admin User</h5>
                                                <p class="text-muted mb-2">
                                                    Blog Management System Administrator
                                                </p>

                                                <span class="badge bg-success">
                                                    Active
                                                </span>
                                            </div>

                                        </div>

                                    </div>
                                </div>
                            </div>

                        </div>

                    </div>
                </section>
            </main>
    </body>


    </html>