<%- include('partials/authHeader') %>

    <body>
        <%- include('partials/aside') %>

            <!-- <a href="/auth/logOut">logOut</a> -->
            <main class="main-wrapper">
                <!-- ========== header start ========== -->
                <header class="header">
                    <div class="container-fluid">
                        <div class="row">
                            <div class="col-lg-5 col-md-5 col-6">
                                <div class="header-left d-flex align-items-center">
                                    <div class="menu-toggle-btn mr-15">
                                        <button id="menu-toggle" class="main-btn primary-btn btn-hover">
                                            <i class="lni lni-chevron-left me-2"></i> Menu
                                        </button>
                                    </div>
                                    <div class="header-search d-none d-md-flex">
                                        <form action="#">
                                            <input type="text" placeholder="Search..." />
                                            <button><i class="lni lni-search-alt"></i></button>
                                        </form>
                                    </div>
                                </div>
                            </div>
                            <div class="col-lg-7 col-md-7 col-6">
                                <div class="header-right d-flex justify-content-end align-items-center">

                                    <!-- Profile -->
                                    <!-- Profile (Hide on Mobile) -->
                                    <div class="profile-box me-4 d-none d-md-block">
                                        <div class="profile-info">
                                            <div class="info d-flex align-items-center">
                                                <div class="image me-2">
                                                    <img src="../assets/images/profile/profile-image.png" alt="profile">
                                                </div>
                                                <div>
                                                    <h6 class="fw-600 mb-0">Adam Joe</h6>
                                                    <small class="text-muted">Admin</small>
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                    <!-- Logout Button -->
                                    <a href="/auth/logOut"
                                        class="btn btn-outline-danger rounded-pill px-4 py-2 d-flex align-items-center gap-2">
                                        <i class="lni lni-exit"></i>
                                        <span>Logout</span>
                                    </a>

                                </div>
                            </div>
                        </div>
                    </div>
                </header>
                <!-- ========== header end ========== -->

                <!-- ========== View Blogs Section Start ========== -->
                <section class="section mt-5">
                    <div class="container-fluid">

                        <div class="card-style shadow-sm">

                            <!-- Header -->
                            <div class="d-flex justify-content-between align-items-center mb-4 pb-3 border-bottom">
                                <div>
                                    <h4 class="mb-1 fw-bold">All Blogs</h4>
                                    <p class="text-muted mb-0">
                                        Manage and organize your blog posts.
                                    </p>
                                </div>

                                <a href="/blogs/add" class="main-btn py-2 px-3 rounded-3 primary-btn btn-hover">
                                    <i class="lni lni-plus me-2"></i>
                                    Add Blog
                                </a>
                            </div>

                            <!-- Table -->
                            <div class="table-responsive">

                                <table class="table align-middle">

                                    <thead class="table-light">
                                        <tr>
                                            <th width="80">#</th>
                                            <th width="120">Image</th>
                                            <th>Title</th>
                                            <th>Author</th>
                                            <th>Category</th>
                                            <th width="150" class="text-center">Actions</th>
                                        </tr>
                                    </thead>

                                    <tbody>

                                        <% blogs.forEach((blog,index)=> { %>

                                            <tr>

                                                <td>
                                                    <strong>
                                                        <%= index + 1 %>
                                                    </strong>
                                                </td>

                                                <td>
                                                    <img src="../<%= blog.image %>" alt="blog-image"
                                                        class="rounded shadow-sm"
                                                        style="width:90px;height:60px;object-fit:cover;">
                                                </td>

                                                <td>
                                                    <div>
                                                        <h6 class="mb-0 fw-semibold">
                                                            <%= blog.title %>
                                                        </h6>
                                                    </div>
                                                </td>

                                                <td>
                                                    <span class="text-dark fw-medium">
                                                        <%= blog.author %>
                                                    </span>
                                                </td>

                                                <td>
                                                    <span class="badge bg-primary px-3 py-2 rounded-pill">
                                                        <%= blog.category %>
                                                    </span>
                                                </td>

                                                <td>
                                                    <div class="action-btns">

                                                        <!-- View -->
                                                        <a href="/blogs/view/<%= blog._id %>"
                                                            class="btn btn-info btn-sm">
                                                            <i class="lni lni-eye"></i>
                                                        </a>

                                                        <!-- Edit -->
                                                        <a href="/blogs/edit/<%= blog._id %>"
                                                            class="btn btn-warning btn-sm">
                                                            <i class="lni lni-pencil"></i>
                                                        </a>

                                                        <!-- Delete -->
                                                        <a href="/blogs/delete/<%= blog._id %>"
                                                            class="btn btn-danger btn-sm"
                                                            onclick="return confirm('Delete this blog?')">
                                                            <i class="lni lni-trash-can"></i>
                                                        </a>

                                                    </div>
                                                </td>

                                            </tr>

                                            <% }) %>

                                    </tbody>

                                </table>

                            </div>

                        </div>

                    </div>
                </section>
                <!-- ========== View Blogs Section End ========== -->

            </main>
    </body>


    </html>